<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence https://jakarta.ee/xml/ns/persistence/persistence_3_1.xsd"
             version="3.1">

    <persistence-unit name="kundenverwaltungPU" transaction-type="RESOURCE_LOCAL">

        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>

        <properties>
            <!-- PostgreSQL Verbindungseinstellungen -->
            <!-- HINWEIS: Zugangsdaten vor Abgabe in GitHub ggf. über Umgebungsvariablen auslagern -->
            <property name="jakarta.persistence.jdbc.driver"   value="org.postgresql.Driver"/>
            <property name="jakarta.persistence.jdbc.url"      value="jdbc:postgresql://localhost:5432/kundenverwaltung"/>
            <property name="jakarta.persistence.jdbc.user"     value="postgres"/>
            <property name="jakarta.persistence.jdbc.password" value="Start.123"/>

            <!-- Hibernate Einstellungen -->
            <property name="hibernate.dialect"        value="org.hibernate.dialect.PostgreSQLDialect"/>
            <!-- update: Tabellen automatisch erstellen/anpassen, nie Daten löschen -->
            <property name="hibernate.hbm2ddl.auto"   value="update"/>
            <property name="hibernate.show_sql"        value="true"/>
            <property name="hibernate.format_sql"      value="true"/>
        </properties>

    </persistence-unit>
</persistence>
